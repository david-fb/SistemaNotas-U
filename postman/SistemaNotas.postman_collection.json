{
  "info": {
    "name": "Sistema de Notas API",
    "description": "Colección completa de requests para el Sistema de Gestión de Notas Estudiantiles. Todos los endpoints requieren autenticación via token Bearer.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "description": "Autenticación y sesión",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) {",
                  "    pm.collectionVariables.set('token', res.token);",
                  "    console.log('Token guardado:', res.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"correo\": \"admin@notas.com\",\n  \"password\": \"1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Inicia sesión con correo y contraseña. El token se guarda automáticamente en {{token}}"
          }
        },
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('token', '');"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Cierra sesión y limpia el token de la colección"
          }
        }
      ]
    },
    {
      "name": "Usuarios",
      "description": "Gestión de usuarios (solo admin)",
      "item": [
        {
          "name": "Listar usuarios",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/usuarios",
              "host": ["{{baseUrl}}"],
              "path": ["api", "usuarios"]
            },
            "description": "Lista todos los usuarios. Requiere rol admin."
          }
        },
        {
          "name": "Obtener usuario por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/usuarios/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "usuarios", "1"]
            },
            "description": "Obtiene un usuario por su ID. Cambia el ID en la URL."
          }
        },
        {
          "name": "Crear usuario",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Pedro Prueba\",\n  \"correo\": \"pedro@notas.com\",\n  \"password\": \"1234\",\n  \"rol\": \"estudiante\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/usuarios",
              "host": ["{{baseUrl}}"],
              "path": ["api", "usuarios"]
            },
            "description": "Crea un nuevo usuario. Roles válidos: admin, profesor, estudiante. Requiere rol admin."
          }
        },
        {
          "name": "Editar usuario",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Pedro Editado\",\n  \"correo\": \"pedro@notas.com\",\n  \"rol\": \"profesor\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/usuarios/9",
              "host": ["{{baseUrl}}"],
              "path": ["api", "usuarios", "9"]
            },
            "description": "Edita nombre, correo y rol de un usuario. Requiere rol admin."
          }
        },
        {
          "name": "Desactivar usuario",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/usuarios/9",
              "host": ["{{baseUrl}}"],
              "path": ["api", "usuarios", "9"]
            },
            "description": "Desactiva un usuario (no lo elimina). Requiere rol admin."
          }
        }
      ]
    },
    {
      "name": "Semestres",
      "description": "Gestión de semestres académicos",
      "item": [
        {
          "name": "Listar semestres",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/semestres",
              "host": ["{{baseUrl}}"],
              "path": ["api", "semestres"]
            },
            "description": "Lista todos los semestres. Todos los roles pueden acceder."
          }
        },
        {
          "name": "Crear semestre",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"2025-2\",\n  \"fechaInicio\": \"2025-07-14\",\n  \"fechaFin\": \"2025-12-05\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/semestres",
              "host": ["{{baseUrl}}"],
              "path": ["api", "semestres"]
            },
            "description": "Crea un nuevo semestre. Requiere rol admin. Formato de fecha: YYYY-MM-DD"
          }
        }
      ]
    },
    {
      "name": "Cursos",
      "description": "Gestión de cursos y cursos del profesor",
      "item": [
        {
          "name": "Listar todos los cursos",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/cursos",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cursos"]
            },
            "description": "Lista todos los cursos. Requiere rol admin."
          }
        },
        {
          "name": "Obtener curso por ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/cursos/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cursos", "1"]
            },
            "description": "Obtiene un curso por su ID. Todos los roles pueden acceder."
          }
        },
        {
          "name": "Mis cursos (profesor)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/mis-cursos",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mis-cursos"]
            },
            "description": "Lista los cursos asignados al profesor autenticado. Requiere rol profesor."
          }
        },
        {
          "name": "Crear curso",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Ingeniería de Software\",\n  \"codigo\": \"IS-501\",\n  \"profesorId\": 2,\n  \"semestreId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cursos",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cursos"]
            },
            "description": "Crea un nuevo curso. Requiere rol admin. El código debe ser único."
          }
        }
      ]
    },
    {
      "name": "Matrículas",
      "description": "Gestión de matrículas de estudiantes en cursos",
      "item": [
        {
          "name": "Listar matrículas de un curso",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/matriculas?cursoId=1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "matriculas"],
              "query": [{ "key": "cursoId", "value": "1" }]
            },
            "description": "Lista todos los estudiantes matriculados en un curso."
          }
        },
        {
          "name": "Matricular estudiante",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cursoId\": 1,\n  \"estudianteId\": 4\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/matriculas",
              "host": ["{{baseUrl}}"],
              "path": ["api", "matriculas"]
            },
            "description": "Matricula un estudiante en un curso. Requiere rol admin. La fecha se genera automáticamente si no se envía."
          }
        },
        {
          "name": "Desmatricular estudiante",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/matriculas?cursoId=1&estudianteId=4",
              "host": ["{{baseUrl}}"],
              "path": ["api", "matriculas"],
              "query": [
                { "key": "cursoId", "value": "1" },
                { "key": "estudianteId", "value": "4" }
              ]
            },
            "description": "Desmatricula un estudiante de un curso. Requiere rol admin."
          }
        }
      ]
    },
    {
      "name": "Cortes",
      "description": "Gestión de cortes/actividades evaluativas",
      "item": [
        {
          "name": "Listar cortes de un curso",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/cortes/curso/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cortes", "curso", "1"]
            },
            "description": "Lista todos los cortes de un curso (ordenados por id ASC). Cambiar el ID al final de la URL. Todos los roles pueden acceder."
          }
        },
        {
          "name": "Crear corte",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cursoId\": 1,\n  \"porcentaje\": 30\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/cortes",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cortes"]
            },
            "description": "Crea un nuevo corte. Requiere rol profesor o admin. La suma de porcentajes no puede exceder 100%."
          }
        },
        {
          "name": "Eliminar corte",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/cortes/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "cortes", "1"]
            },
            "description": "Elimina un corte. Requiere rol profesor o admin."
          }
        }
      ]
    },
    {
      "name": "Notas",
      "description": "Gestión de calificaciones y vista de notas",
      "item": [
        {
          "name": "Listar notas de un curso",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/notas/curso/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notas", "curso", "1"]
            },
            "description": "Lista todas las notas de un curso. Cambiar el ID al final de la URL. Requiere rol profesor."
          }
        },
        {
          "name": "Registrar nota",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"estudianteId\": 4,\n  \"corteId\": 1,\n  \"valor\": 4.5\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/notas",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notas"]
            },
            "description": "Registra una nota para un estudiante en un corte. Requiere rol profesor. Valor entre 0.0 y 5.0."
          }
        },
        {
          "name": "Actualizar nota",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"valor\": 3.8\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/notas/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notas", "1"]
            },
            "description": "Actualiza el valor de una nota. Requiere rol profesor."
          }
        },
        {
          "name": "Eliminar nota",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/notas/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "notas", "1"]
            },
            "description": "Elimina una nota. Requiere rol profesor."
          }
        },
        {
          "name": "Mis notas (estudiante)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/mis-notas",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mis-notas"]
            },
            "description": "Retorna todas las notas del estudiante autenticado, agrupadas por curso. Requiere rol estudiante."
          }
        },
        {
          "name": "Mi promedio general",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/mis-notas/promedio",
              "host": ["{{baseUrl}}"],
              "path": ["api", "mis-notas", "promedio"]
            },
            "description": "Retorna el promedio general del estudiante autenticado. Requiere rol estudiante."
          }
        }
      ]
    }
  ]
}
